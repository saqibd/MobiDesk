{
  "expo": {
    "name": "MobiDesk",
    "slug": "mobidesk",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "entryPoint": "./App.tsx",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {},
    "android": {},
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-asset"
    ]
  }
}
